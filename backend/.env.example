# Server
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS + OAuth redirects)
FRONTEND_URL=http://localhost:5173

# Google OAuth2 (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# Microsoft OAuth2 (https://portal.azure.com)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:5000/auth/microsoft/callback

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# AES-256-GCM encryption key — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: Never change this after data is stored — all existing rows become unreadable
ENCRYPTION_KEY=

# Gemini AI (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Neon PostgreSQL (https://neon.tech)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
